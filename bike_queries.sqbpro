<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="bike_sales.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="2247"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="indian_bike_sales" custom_title="0" dock_id="1" table="4,17:mainindian_bike_sales"/><dock_state state="000000ff00000000fd00000001000000020000000000000000fc0100000001fb000000160064006f0063006b00420072006f00770073006500310100000000ffffffff0000011300ffffff000000000000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings/></tab_browse><tab_sql><sql name="SQL 1*">SELECT * FROM indian_bike_sales LIMIT 10;
SELECT COUNT(*) AS Total_Bikes FROM indian_bike_sales;
SELECT Brand, COUNT(*) AS Units_Sold
FROM indian_bike_sales
GROUP BY Brand
ORDER BY Units_Sold DESC;
SELECT Brand,
ROUND(AVG(CAST(&quot;Price (INR)&quot; AS FLOAT)), 0) AS Avg_Price,
ROUND(AVG(CAST(&quot;Resale Price (INR)&quot; AS FLOAT)), 0) AS Avg_Resale
FROM indian_bike_sales
GROUP BY Brand
ORDER BY Avg_Price DESC;
SELECT &quot;Fuel Type&quot;, COUNT(*) AS Count,
ROUND(COUNT(*) * 100.0 / (SELECT COUNT(*) FROM indian_bike_sales), 1) AS Share_Pct
FROM indian_bike_sales
GROUP BY &quot;Fuel Type&quot;;
SELECT 
    &quot;Owner Type&quot;,
    ROUND(AVG(CAST(&quot;Price (INR)&quot; AS FLOAT)), 0) AS Avg_Price,
    ROUND(AVG(CAST(&quot;Resale Price (INR)&quot; AS FLOAT)), 0) AS Avg_Resale,
    ROUND(
        AVG(CAST(&quot;Price (INR)&quot; AS FLOAT)) - 
        AVG(CAST(&quot;Resale Price (INR)&quot; AS FLOAT)), 
    0) AS Avg_Depreciation
FROM indian_bike_sales
GROUP BY &quot;Owner Type&quot;;
SELECT Brand,
ROUND(AVG(CAST(&quot;Mileage (km/l)&quot; AS FLOAT)), 2) AS Avg_Mileage,
ROUND(AVG(CAST(&quot;Engine Capacity (cc)&quot; AS FLOAT)), 0) AS Avg_Engine_CC
FROM indian_bike_sales
GROUP BY Brand
ORDER BY Avg_Mileage DESC;
SELECT &quot;City Tier&quot;,
ROUND(AVG(CAST(&quot;Avg Daily Distance (km)&quot; AS FLOAT)), 2) AS Avg_Km_Day,
COUNT(*) AS Bikes
FROM indian_bike_sales
GROUP BY &quot;City Tier&quot;;
SELECT &quot;Insurance Status&quot;, COUNT(*) AS Count
FROM indian_bike_sales
GROUP BY &quot;Insurance Status&quot;;
SELECT Brand, Model, MAX(CAST(&quot;Price (INR)&quot; AS INTEGER)) AS Max_Price
FROM indian_bike_sales
GROUP BY Brand, Model
ORDER BY Max_Price DESC
LIMIT 10;
</sql><current_tab id="0"/></tab_sql></sqlb_project>
